# Copie este arquivo para .env e preencha os valores
# Nunca commite o .env com credenciais reais

# MongoDB Atlas: Databases > Connect > Drivers > copie a connection string
MONGO_URL=mongodb+srv://usuario:senha@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=uaifix

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-forte-de-producao

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

ADMIN_EMAIL=cassio@uaifix.com.br
ADMIN_PASSWORD=troque-por-senha-forte

UPLOADS_DIR=uploads

# Em produção: URL real da Vercel e do Render
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
